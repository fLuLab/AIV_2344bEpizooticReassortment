			<date value="2019.164383561644" direction="forwards" units="years"/>
		</taxon>
		<taxon id="H5N8|2344b|EPI_ISL_603233|galliformes|bulgaria|1_2_15_2_1_13_1_2|2020-06-03">
			<date value="2020.4207650273224" direction="forwards" units="years"/>
		</taxon>
		<taxon id="H5N8|2344b|EPI_ISL_603229|galliformes|bulgaria|1_2_15_2_1_13_1_2|2019-04-05">
